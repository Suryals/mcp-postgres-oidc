{
  "realm": "mcp-db",
  "displayName": "MCP Banking DB",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "resetPasswordAllowed": true,
  "accessTokenLifespan": 3600,

  "roles": {
    "realm": [
      { "name": "db_admin",    "description": "Full database access — all columns unmasked, can read audit_logs" },
      { "name": "db_analyst",  "description": "Analyst access — partial PII masking, no salary/national_id" },
      { "name": "db_readonly", "description": "Read-only access — all sensitive columns fully masked" }
    ]
  },

  "clientScopes": [
    {
      "name": "mcp-roles",
      "description": "Realm roles + identity claims. A realm DEFAULT scope so every client — including dynamically-registered MCP clients — emits realm_access.roles.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        },
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "username",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "preferred_username",
            "jsonType.label": "String"
          }
        },
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "email",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "email",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],

  "defaultDefaultClientScopes": ["mcp-roles"],
  "defaultOptionalClientScopes": [],

  "clients": [
    {
      "clientId": "mcp-test",
      "name": "MCP Test Client (Password Grant — local CLI only)",
      "description": "Direct-access grant for scripts/get_token.sh and smoke tests. Not used by the browser OAuth flow.",
      "enabled": true,
      "publicClient": false,
      "secret": "${MCP_TEST_CLIENT_SECRET}",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true
    }
  ],

  "users": [
    {
      "username": "alice",
      "email": "alice@banking.demo",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Alice",
      "lastName": "Admin",
      "credentials": [ { "type": "password", "value": "${ALICE_PASSWORD}", "temporary": false } ],
      "realmRoles": ["db_admin"]
    },
    {
      "username": "bob",
      "email": "bob@banking.demo",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Bob",
      "lastName": "Analyst",
      "credentials": [ { "type": "password", "value": "${BOB_PASSWORD}", "temporary": false } ],
      "realmRoles": ["db_analyst"]
    },
    {
      "username": "carol",
      "email": "carol@banking.demo",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Carol",
      "lastName": "Readonly",
      "credentials": [ { "type": "password", "value": "${CAROL_PASSWORD}", "temporary": false } ],
      "realmRoles": ["db_readonly"]
    }
  ],

  "components": {
    "org.keycloak.services.clientregistration.policy.ClientRegistrationPolicy": [
      {
        "name": "Trusted Hosts",
        "providerId": "trusted-hosts",
        "subType": "anonymous",
        "subComponents": {},
        "config": {
          "host-sending-registration-request-must-match": ["false"],
          "client-uris-must-match": ["true"],
          "trusted-hosts": [
            "localhost", "127.0.0.1",
            "github.com",
            "mcp-postgres.traefik.test", "traefik.test",
            "claude.ai", "claude.com"
          ]
        }
      }
    ]
  }
}
